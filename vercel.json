{
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/cron-trial",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/reminder-rdv",
      "schedule": "0 8 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/app-config", "destination": "/api/app-config.js" },
    { "source": "/api/brevo-contacts", "destination": "/api/brevo-contacts.js" },
    { "source": "/api/brevo-tracking", "destination": "/api/brevo-tracking.js" },
    { "source": "/api/calendar-list", "destination": "/api/calendar-list.js" },
    { "source": "/api/gmail-emails", "destination": "/api/gmail-emails.js" },
    { "source": "/api/send-email", "destination": "/api/send-email.js" },
    { "source": "/api/send-welcome", "destination": "/api/send-welcome.js" },
    { "source": "/api/send-magic-link", "destination": "/api/send-magic-link.js" },
    { "source": "/api/client-orders", "destination": "/api/client-orders.js" },
    { "source": "/api/client-documents", "destination": "/api/client-documents.js" },
    { "source": "/api/cal-webhook", "destination": "/api/cal-webhook.js" },
    { "source": "/api/cron-trial", "destination": "/api/cron-trial.js" },
    { "source": "/api/config", "destination": "/api/config.js" },
    { "source": "/api/booking-request", "destination": "/api/booking-request.js" },
    { "source": "/api/booking-page", "destination": "/api/booking-page.js" },
    { "source": "/api/confirm-rdv", "destination": "/api/confirm-rdv.js" },
    { "source": "/api/reminder-rdv", "destination": "/api/reminder-rdv.js" },
    { "source": "/booking", "destination": "/api/booking-page" },
    { "source": "/extranet", "destination": "/index.html" },
    { "source": "/extranet-app", "destination": "/extranet-app.html" },
    { "source": "/api/get-reservations", "destination": "/api/get-reservations.js" },
    { "source": "/api/send-welcome-agency", "destination": "/api/send-welcome-agency.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
