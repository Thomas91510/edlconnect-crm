{
  "version": 2,
  "functions": {
    "send-email.js": { "runtime": "@vercel/node@3" },
    "gmail-emails.js": { "runtime": "@vercel/node@3" },
    "brevo-contacts.js": { "runtime": "@vercel/node@3" },
    "brevo-tracking.js": { "runtime": "@vercel/node@3" },
    "calendar-create.js": { "runtime": "@vercel/node@3" },
    "calendar-list.js": { "runtime": "@vercel/node@3" },
    "config.js": { "runtime": "@vercel/node@3" }
  },
  "routes": [
    { "src": "/api/send-email", "dest": "/send-email.js" },
    { "src": "/api/gmail-emails", "dest": "/gmail-emails.js" },
    { "src": "/api/brevo-contacts", "dest": "/brevo-contacts.js" },
    { "src": "/api/brevo-tracking", "dest": "/brevo-tracking.js" },
    { "src": "/api/calendar-create", "dest": "/calendar-create.js" },
    { "src": "/api/calendar-list", "dest": "/calendar-list.js" },
    { "src": "/api/config", "dest": "/config.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
